# Discord bot token (privileged Message Content intent enabled in dev portal)
SABLE_ROLES_DISCORD_TOKEN=

# Per-guild fit-check channel + org mapping.
# Shape: {"<guild_id>": {"org_id": "<org_id>", "channel_id": "<fitcheck_channel_id>"}}
SABLE_ROLES_FITCHECK_CHANNELS_JSON={}

# Discord guild_id -> sable.db org_id (used for /streak resolution + unconfigured-guild filtering).
# Shape: {"<guild_id>": "<org_id>"}
SABLE_ROLES_GUILD_TO_ORG_JSON={}

# Optional: per-guild #sable-ops health channel.
# V1: not used (bot has no overwrite for that channel). Reserved for future.
SABLE_ROLES_HEALTH_CHANNELS_JSON={}
