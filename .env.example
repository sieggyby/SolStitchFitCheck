# Discord bot token (privileged Message Content intent enabled in dev portal)
SABLE_ROLES_DISCORD_TOKEN=

# Per-guild fit-check channel + org mapping.
# Shape: {"<guild_id>": {"org_id": "<org_id>", "channel_id": "<fitcheck_channel_id>"}}
SABLE_ROLES_FITCHECK_CHANNELS_JSON={}

# Discord guild_id -> sable.db org_id (used for /streak resolution + unconfigured-guild filtering).
# Shape: {"<guild_id>": "<org_id>"}
SABLE_ROLES_GUILD_TO_ORG_JSON={}

# Optional: per-guild #sable-ops health channel.
# V1: not used (bot has no overwrite for that channel). Reserved for future.
SABLE_ROLES_HEALTH_CHANNELS_JSON={}

# Per-guild list of role IDs whose holders count as "mods" (gates /relax-mode +
# V2 burn-me commands). Discord Administrator does NOT auto-grant mod status —
# include the role explicitly. Shape: {"<guild_id>": ["<role_id>", ...]}
SABLE_ROLES_MOD_ROLES_JSON={}

# --- Burn-me feature config (V2) ---

# Anthropic API key for /burn-me LLM (vision) calls. REQUIRED for the burn-me
# feature. The anthropic SDK auto-reads this from the environment; config.py
# also re-exposes it for boot-time visibility. Get from console.anthropic.com.
ANTHROPIC_API_KEY=

# Model id for /burn-me roasts. Sonnet 4.6 is the locked default; override only
# for cost experimentation (e.g. claude-haiku-4-5 for cheaper Haiku 4.5).
SABLE_ROLES_BURN_MODEL=claude-sonnet-4-6

# Random-bypass probability per image post by an inner-circle member (0.025 = 2.5%).
# Set to 1.0 temporarily for deterministic smoke-testing of the random path.
SABLE_ROLES_BURN_RANDOM_PROB=0.025

# Per-target dedup window (rolling UTC days) for random-bypass roasts.
SABLE_ROLES_BURN_RANDOM_DEDUP_DAYS=7

# Per-user invocation cooldown for /burn-me (seconds).
SABLE_ROLES_BURN_INVOKE_COOLDOWN_SECONDS=30

# Per-user daily cap on total roasts (opt-in + random both count). Set to 0 to
# effectively disable the feature without code changes.
SABLE_ROLES_BURN_DAILY_CAP_PER_USER=20

# Inner-circle: per-guild role-ID allowlist eligible for random-bypass roasts.
# Shape: {"<guild_id>": ["<role_id>", ...]}
# SolStitch reference (guild 1501026101730869290): ROLE_ATELIER 1501073363991400521,
# ROLE_SOLSTITCH_TEAM 1501073364893175828, ROLE_ARTIST_IN_RESIDENCE 1501073366608515192.
SABLE_ROLES_INNER_CIRCLE_ROLES_JSON={}

# Inner-circle: per-guild user-ID allowlist (union with role-based above).
# Shape: {"<guild_id>": ["<user_id>", ...]}
SABLE_ROLES_INNER_CIRCLE_USERS_JSON={}

# --- /roast V2 personalization (mig 047) ---

# Peer-roast eligibility: per-guild role-ID allowlist whose holders can
# invoke peer /roast. Shape: {"<guild_id>": ["<role_id>", ...]}
SABLE_ROLES_PEER_ROAST_ROLES_JSON={}

# /set-personalize-mode admin allowlist (user IDs, per guild). Not role-based —
# lets a single operator (e.g. Arf) flip personalization without granting every
# mod the keys. Shape: {"<guild_id>": ["<user_id>", ...]}
SABLE_ROLES_PERSONALIZE_ADMINS_JSON={}

# Vibe observation: per-guild channel-ID allowlist the observer reads messages
# from. Empty/missing list for a guild = all text channels the bot has read
# access to. Shape: {"<guild_id>": ["<channel_id>", ...]}
SABLE_ROLES_OBSERVATION_CHANNELS_JSON={}

# Weekly cadence for the vibe inference cron (whole days).
SABLE_ROLES_VIBE_INFERENCE_INTERVAL_DAYS=7

# Model id for vibe-summarization calls. Sonnet 4.6 default.
SABLE_ROLES_VIBE_INFERENCE_MODEL=claude-sonnet-4-6

# Rolling window the vibe inference looks back over per refresh (days).
SABLE_ROLES_VIBE_OBSERVATION_WINDOW_DAYS=30

# Hard env kill switch for the entire vibe pipeline (raw observation + rollup +
# inference). Distinct from the per-guild /set-personalize-mode toggle — this
# short-circuits BEFORE any DB read so a single deploy can stop all data
# collection across guilds. Truthy: "true" (case-insensitive). Anything else = off.
SABLE_ROLES_VIBE_OBSERVATION_ENABLED=true
